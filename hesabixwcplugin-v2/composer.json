{
  "name": "hesabix/woocommerce-v2",
  "description": "اتصال ووکامرس به نسخه جدید حسابیکس با API پیشرفته",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Hesabix Team",
      "email": "support@hesabix.ir",
      "homepage": "https://hesabix.ir"
    }
  ],
  "keywords": [
    "wordpress",
    "woocommerce",
    "hesabix",
    "accounting",
    "invoice",
    "persian",
    "jalali"
  ],
  "homepage": "https://hesabix.ir",
  "support": {
    "email": "support@hesabix.ir",
    "issues": "https://hesabix.ir/support"
  },
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "squizlabs/php_codesniffer": "^3.5"
  },
  "autoload": {
    "psr-4": {
      "Hesabix\\V2\\": "includes/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "phpcs": "phpcs --standard=WordPress includes/ admin/",
    "phpcbf": "phpcbf --standard=WordPress includes/ admin/"
  },
  "config": {
    "platform": {
      "php": "7.4"
    }
  }
}

