APP_NAME=Hesabix API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0

# Database
DB_USER=root
DB_PASSWORD=136431
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hesabixpy
SQLALCHEMY_ECHO=false
# Database Connection Pool Settings - Phase 1 Optimization
# افزایش Connection Pool برای مقیاس‌پذیری بالاتر
DB_POOL_SIZE=50  # اتصالات پایه در Pool (افزایش از 20)
DB_MAX_OVERFLOW=50  # اتصالات اضافی در صورت نیاز (افزایش از 30)
DB_POOL_TIMEOUT=30  # Timeout بیشتر برای Pool (افزایش از 10)
DB_POOL_RECYCLE=3600  # Recycle اتصالات هر ساعت

# Redis Cache (optional - برای بهینه‌سازی performance)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Logging
LOG_LEVEL=INFO

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SECRET_HEADER=
TELEGRAM_PROXY_ENABLED=false
TELEGRAM_PROXY_BASE_URL=
TELEGRAM_PROXY_API_KEY=

# SMS (optional)
SMS_PROVIDER_NAME=
SMS_API_KEY=
SMS_SENDER=

# Share link defaults
SHARE_LINK_CODE_LENGTH=9
SHARE_LINK_DEFAULT_TTL_HOURS=168
SHARE_LINK_MAX_TTL_HOURS=720
SHARE_LINK_PUBLIC_BASE_URL=https://app.hesabix.com/p
SHARE_LINK_SECRET=change_me_share_link
SHARE_LINK_PUBLIC_APP_URL=https://app.hesabix.com/public

# AI Voice Chat (optional — local STT/TTS, no cloud speech API)
# Install: pip install -e ".[voice]"  or  bash scripts/ensure_voice_chat.sh
# VOICE_ENABLED=true
# VOICE_TTS_ENGINE=piper
# VOICE_TTS_PIPER_VOICE_FA=fa_IR-ganji-medium
# VOICE_TTS_PIPER_MODELS_DIR=/var/lib/hesabix/voice-data/piper
# VOICE_TTS_MODEL_PATH=/var/lib/hesabix/voice-data/piper/fa_IR-ganji-medium.onnx
# VOICE_DATA_COLLECTION_DIR=/var/lib/hesabix/voice-data
# VOICE_DATA_COLLECTION_ENABLED=false

