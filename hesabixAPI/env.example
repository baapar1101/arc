APP_NAME=Hesabix API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
APP_VERSION=0.1.0

# Database
DB_USER=root
DB_PASSWORD=136431
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hesabixpy
SQLALCHEMY_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=10

# Logging
LOG_LEVEL=INFO

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_SECRET_HEADER=

# SMS (optional)
SMS_PROVIDER_NAME=
SMS_API_KEY=
SMS_SENDER=

# Share link defaults
SHARE_LINK_CODE_LENGTH=9
SHARE_LINK_DEFAULT_TTL_HOURS=168
SHARE_LINK_MAX_TTL_HOURS=720
SHARE_LINK_PUBLIC_BASE_URL=https://app.hesabix.com/p
SHARE_LINK_SECRET=change_me_share_link
SHARE_LINK_PUBLIC_APP_URL=https://app.hesabix.com/public

