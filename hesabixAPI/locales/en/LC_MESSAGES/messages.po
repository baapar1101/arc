msgid "ROLLBACK_SOURCE_DOCUMENT_MONETIZATION"
msgstr "document services charge (system)"

msgid "ROLLBACK_SOURCE_STORAGE_INVOICE"
msgstr "storage invoice (system)"

msgid "ROLLBACK_REASON_SYSTEM_DOC"
msgstr "This document is a system-internal record ({label}). Removing it may break wallet or billing consistency."

msgid "ROLLBACK_REASON_TAX_WORKSPACE"
msgstr "This document is in the tax workspace; fiscal rollback is blocked until it is cleared from the workspace."

msgid "ROLLBACK_REASON_LOCKED"
msgstr "Document is locked; remove the lock or void it through the proper workflow."

msgid "ROLLBACK_REASON_WALLET_PROTECTED_FALLBACK"
msgstr "This document has protected system wallet transactions; removing the fiscal year is not allowed to preserve financial integrity."

msgid "ROLLBACK_REASON_CHECK_LINES"
msgstr "This document has lines linked to checks; fix check status first."

msgid "ROLLBACK_REASON_AI_INVOICE"
msgstr "This document is linked to AI billing; contact support before rolling back the fiscal year."

msgid "ROLLBACK_PLUGIN_PURCHASE_BLOCK"
msgstr "A successful add-on purchase from the wallet exists in this fiscal year. Removing the current year may break reports or licenses; contact support."

