msgstr "Document {code} (type: {doc_type}) — {reason}"

msgid "ROLLBACK_BLOCK_PREV_YEAR_LINE"
msgstr "Previous year — {kind} document ({code}) — {reason}"

msgid "ROLLBACK_DOC_KIND_YEAR_END_CLOSING"
msgstr "year-end closing"

msgid "ROLLBACK_DOC_KIND_PERSON_BALANCE"
msgstr "person balance"

msgid "ROLLBACK_WAREHOUSE_PURGE_FAILED"
msgstr "Could not delete warehouse documents for this fiscal year. Check database connection or locks. Details: {detail}"

msgid "ROLLBACK_REPAIR_PURGE_FAILED"
msgstr "Could not delete repair-shop orders for this fiscal year. Fix linked documents first. Details: {detail}"

msgid "ROLLBACK_DELETE_RECEIPT_PAYMENT_FAILED"
msgstr "Receipt/payment document \"{code}\" could not be deleted. Contact support."

msgid "ROLLBACK_DELETE_EXPENSE_INCOME_FAILED"
msgstr "Expense/income document \"{code}\" could not be deleted. Check database constraints."

msgid "ROLLBACK_DOCUMENTS_REMAINING"
msgstr "After deletion attempts, {count} document(s) still remain in this fiscal year. An unsupported document type may exist; contact support with the fiscal year id."

msgid "ROLLBACK_BLOCKED"
msgstr "The current fiscal year cannot be removed due to safety or system dependencies. Resolve the items shown in the preview block list, then refresh the preview."

msgid "ROLLBACK_STALE_TOKEN"
msgstr "The current or previous fiscal year changed between preview and confirm. Take a fresh preview and run immediately."

msgid "ROLLBACK_FAILED"
msgstr "Fiscal rollback did not complete; no changes were saved. Check network, server load, or database errors and try again. Details: {detail}"

msgid "ROLLBACK_SUCCESS_MESSAGE"
msgstr "Current fiscal year was removed; the previous year is now current. You can register or edit documents in that year subject to its rules."

msgid "ROLLBACK_ACTIVITY_LOG"
msgstr "Removed fiscal year {removed} and set current to {current}"

msgid "ROLLBACK_PREVIEW_FAILED"
msgstr "Fiscal rollback preview failed. Check connectivity and try again. ({error})"

msgid "ROLLBACK_EXECUTE_FAILED"
msgstr "Fiscal rollback failed unexpectedly. If it persists, contact support. ({error})"

